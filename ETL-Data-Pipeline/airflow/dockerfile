FROM apache/airflow:3.1.5

USER root

# Install OpenJDK 17 for PySpark
RUN apt-get update \
  && apt-get install -y --no-install-recommends \
         openjdk-17-jre-headless \
  && apt-get autoremove -yqq --purge \
  && apt-get clean \
  && rm -rf /var/lib/apt/lists/*

USER airflow

# Install project dependencies into the image so they don't download on startup
RUN pip install --no-cache-dir pyspark duckdb pandas web3 eth-abi
